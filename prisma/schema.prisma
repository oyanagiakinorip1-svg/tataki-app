// prisma/schema.prisma
 
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" // Prisma Client の生成先（Prisma 7 では output が必須）
}
 
datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique // ユニーク制約（同じ値は入れられない）
  projects  Project[] // 1対多のリレーション（Userは複数のProjectを持てる）
  createdAt DateTime @default(now()) @map("created_at") // デフォルト値を現在時刻にする & カラム名は created_at にする
 
  @@map("users")  // テーブル名を "users" にする
}

model Project {
  id          String   @id @default(uuid())
  title       String
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  datas       Data[]
  files       File[]
  slide       Slide?
  createdAt   DateTime @default(now()) @map("created_at")
 
  @@map("projects") 
}

model Data {
  id          String   @id @default(uuid())
  title       String
  projectId   String   @map("project_id")
  content     String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
 
  @@map("datas")
}

model File {
  id          String   @id @default(uuid())
  name        String
  projectId   String   @map("project_id")
  url         String
  type        String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
 
  @@map("files")
}

model Slide {
  id          String   @id @default(uuid())
  title       String
  projectId   String   @unique @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
 
  @@map("slides")
}